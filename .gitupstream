# Configures the sync-repo-from-upstream workflow. Schema:
# https://github.com/nsheaps-oura/github-actions/blob/main/.github/workflows/sync-repo-from-upstream.yaml
#
# (See also nsheaps/agents' .gitupstream for the intra-repo main->edge variant
# this format is modeled on: sync-main-to-edge.yaml.)
version: 1
cross_repo_sync:
  - upstream_repo: nsheaps/dotfiles
    upstream_branch: main
    target_branch: main
    private: false
