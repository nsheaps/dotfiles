#!/usr/bin/env bash
# dotfiles - manage deployment of this dotfiles repo into $HOME
#
# Subcommands:
#   wire            Deploy dotfiles from the repo into $HOME (symlinks +
#                   managed rc sections + .config symlinks).
#   check           Report whether dotfiles are wired into $HOME.
#                   Exits 0 if wired, non-zero otherwise.
#   ensure-wired    Run check; if not wired, run wire non-interactively.
#                   Always exits 0 (used by the Homebrew formula post_install).
#   startup         Run the startup.d scripts (bin/run-startup.sh).
#   update          Run the update.d scripts (bin/run-updates.sh).
#   staleness-check Warn on stderr if this checkout is on the wrong branch or
#                   behind the last-fetched remote HEAD. Rate-limited to once
#                   per interval; called from shell startup (see
#                   internal/interactive.d/staleness-check.sh).
#
# This is the global entrypoint installed by the Homebrew formula. When you are
# inside a checkout of the repo, direnv puts the repo's bin/ first on PATH so
# this same script runs against your working copy instead of the installed one.
#
# The repo location is resolved into DOTFILES_DIR (see resolve_dotfiles_dir),
# the single variable the shell config in internal/ relies on.

set -euo pipefail

DOTFILES_VERSION="0.1.0"

# Managed section markers (kept identical across versions so old sections can be
# found and replaced in place).
MARKER_BEGIN="# BEGIN: Managed by dotfiles wire"
MARKER_END="# END: Managed by dotfiles wire"

# -----------------------------------------------------------------------------
# Path / repo resolution
# -----------------------------------------------------------------------------

# Resolve the real directory containing this script, following symlinks.
# Portable (no dependency on `readlink -f`, which BSD/macOS historically lacked).
script_dir() {
  local source="${BASH_SOURCE[0]}" dir
  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}

# Resolve the dotfiles repo root into DOTFILES_DIR. Priority:
#   1. $DOTFILES_DIR if already set and valid (direnv exports this inside a
#      checkout, so local development always wins over the installed copy).
#   2. The script's own location (../internal). Covers both the in-repo copy
#      and the Homebrew install (libexec/bin/dotfiles -> libexec/internal).
#   3. ~/.dotfiles/internal (symlink created by a previous `wire`).
#
# A checkout is considered valid if it has an internal/ directory: internal/
# is dotfiles' own required mechanism (the shell rc loaders, plus the antidote
# and staleness-check drop-ins) that every checkout ships with, unlike _home/
# (personal .config/Library content and personal drop-in scripts), which a
# fresh fork may not have populated yet.
resolve_dotfiles_dir() {
  if [[ -n "${DOTFILES_DIR:-}" && -d "$DOTFILES_DIR/internal" ]]; then
    printf '%s\n' "$DOTFILES_DIR"
    return 0
  fi

  # A real (non-symlink) git checkout at ~/.dotfiles — e.g. from a prior
  # `wire --repo` — is the user's own editable copy and takes priority over
  # the bundled/installed one: if they have their own checkout there, that's
  # the one every subsequent `check`/`wire` should treat as the source of
  # truth, not the Homebrew-managed bundle. This is what makes the --repo
  # choice "stick" across future invocations without needing a state file —
  # the presence of a real checkout at this path is itself the signal.
  if [[ -d "$HOME/.dotfiles/.git" && ! -L "$HOME/.dotfiles" && -d "$HOME/.dotfiles/internal" ]]; then
    (cd "$HOME/.dotfiles" && pwd -P)
    return 0
  fi

  local sdir root
  sdir="$(script_dir)"
  root="$(cd "$sdir/.." && pwd)"
  if [[ -d "$root/internal" ]]; then
    printf '%s\n' "$root"
    return 0
  fi

  if [[ -d "$HOME/.dotfiles/internal" ]]; then
    (cd "$HOME/.dotfiles" && pwd -P)
    return 0
  fi

  echo "dotfiles: error: could not locate the dotfiles repo (no internal/ found)." >&2
  echo "         Set DOTFILES_DIR to your dotfiles checkout and try again." >&2
  return 1
}

# Populated by main() before dispatching to a subcommand. Preserve an
# inherited DOTFILES_DIR (e.g. from the Homebrew wrapper, or direnv in a
# checkout) rather than unconditionally clobbering it — resolve_dotfiles_dir's
# own priority-1 check for it is meaningless otherwise, since this ran before
# that check on every invocation.
DOTFILES_DIR="${DOTFILES_DIR:-}"
TEMPLATES_DIR=""
HOME_DIR="$HOME"

# Set only by the Homebrew wrapper (never by direnv/rc.d), so its presence
# distinguishes "running the brew-installed CLI with no shadowing checkout"
# from "running inside a dev checkout" — see cmd_wire's use of it below.
DOTFILES_DEFAULT_REPO_URL="${DOTFILES_DEFAULT_REPO_URL:-}"

# -----------------------------------------------------------------------------
# wire
# -----------------------------------------------------------------------------

# When true, never prompt: config-file conflicts are skipped (both kept as-is).
NONINTERACTIVE="${DOTFILES_NONINTERACTIVE:-}"

create_symlink() {
  local src="$1"
  local dest="$2"

  if [[ -d "$src" ]]; then
    ln -sfn "$src" "$dest"
    echo "  $dest → $src"
  else
    echo "  Warning: Source directory does not exist: $src"
  fi
}

# Inject or update a managed section in a file.
# Usage: inject_managed_section <target_file> <template_file>
inject_managed_section() {
  local target="$1"
  local template="$2"

  if [[ ! -f "$template" ]]; then
    echo "  Warning: Template not found: $template"
    return 1
  fi

  # Build the managed section content with DOTFILES_DIR expanded
  local section_content
  section_content="$MARKER_BEGIN
export DOTFILES_DIR=\"$DOTFILES_DIR\"
$(cat "$template")
$MARKER_END"

  # Create target file if it doesn't exist
  if [[ ! -f "$target" ]]; then
    echo "$section_content" >"$target"
    echo "  Created $target with managed section"
    return 0
  fi

  # Check if managed section already exists
  if grep -q "$MARKER_BEGIN" "$target" 2>/dev/null; then
    # Replace existing managed section
    local tmpfile content_file
    tmpfile=$(mktemp)
    content_file=$(mktemp)

    # Write content to temp file (awk can't handle newlines in -v)
    echo "$section_content" >"$content_file"

    # Use awk to replace the section, reading replacement from file
    awk -v begin="$MARKER_BEGIN" -v end="$MARKER_END" -v cfile="$content_file" '
      $0 ~ begin { skip=1; while ((getline line < cfile) > 0) print line; close(cfile); next }
      $0 ~ end { skip=0; next }
      !skip { print }
    ' "$target" >"$tmpfile"

    mv "$tmpfile" "$target"
    rm -f "$content_file"
    echo "  Updated managed section in $target"
  else
    # Append managed section to end of file
    echo "" >>"$target"
    echo "$section_content" >>"$target"
    echo "  Appended managed section to $target"
  fi
}

# Symlink a single file from repo to HOME with conflict resolution.
# Usage: link_home_file <repo_subdir> <home_subdir> <relative_path>
# Example: link_home_file "_home/.config" ".config" "mise/config.toml"
link_home_file() {
  local repo_subdir="$1"
  local home_subdir="$2"
  local rel_path="$3"
  local src="$DOTFILES_DIR/$repo_subdir/$rel_path"
  local dest="$HOME_DIR/$home_subdir/$rel_path"
  # Tilde is intentional for display, not expansion
  # shellcheck disable=SC2088
  local display_path="~/$home_subdir/$rel_path"
  local dest_dir
  dest_dir="$(dirname "$dest")"

  # Skip README files - they're for documentation only
  if [[ "$(basename "$rel_path")" == "README.md" ]]; then
    return 0
  fi

  # Create destination directory if needed
  if [[ ! -d "$dest_dir" ]]; then
    mkdir -p "$dest_dir"
  fi

  # Already a correct symlink
  if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
    echo "  Symlink OK: $display_path"
    return 0
  fi

  # If destination doesn't exist, just symlink
  if [[ ! -e "$dest" ]]; then
    ln -s "$src" "$dest"
    echo "  Symlinked: $display_path"
    return 0
  fi

  # If it's a symlink pointing elsewhere, update it
  if [[ -L "$dest" ]]; then
    rm -f "$dest"
    ln -s "$src" "$dest"
    echo "  Updated symlink: $display_path"
    return 0
  fi

  # It's a regular file - check if it matches
  if diff -q "$src" "$dest" >/dev/null 2>&1; then
    # Files match - replace with symlink
    rm -f "$dest"
    ln -s "$src" "$dest"
    echo "  Converted to symlink: $display_path"
    return 0
  fi

  # Files differ. In non-interactive mode (or without a TTY) we cannot safely
  # prompt, so skip and leave both copies untouched.
  if [[ -n "$NONINTERACTIVE" ]] || [[ ! -t 0 ]]; then
    echo "  CONFLICT (skipped): $display_path differs from repo version; left as-is." >&2
    return 0
  fi

  # Files differ - prompt user
  echo ""
  echo "  CONFLICT: $display_path differs from repo version"
  echo ""
  echo "  --- Diff (repo vs home) ---"
  if [[ -t 1 ]]; then
    diff --color=always -u "$src" "$dest" || true
  else
    diff -u "$src" "$dest" || true
  fi
  echo "  --- End diff ---"
  echo ""
  echo "  Options:"
  echo "    [r] Overwrite HOME with repo version"
  echo "    [h] Overwrite repo with HOME version (and commit)"
  echo "    [k] Keep both: 3-way merge with empty base (auto-merges, conflicts if needed)"
  echo "    [s] Skip (keep both as-is, no sync)"
  echo "    [d] Show full diff"
  echo ""

  while true; do
    read -rp "  Choice [r/h/k/s/d]: " choice
    case "$choice" in
    r | R)
      rm -f "$dest"
      ln -s "$src" "$dest"
      echo "  Symlinked $display_path to repo version"
      break
      ;;
    h | H)
      cp "$dest" "$src"
      rm -f "$dest"
      ln -s "$src" "$dest"
      git -C "$DOTFILES_DIR" add "$src"
      git -C "$DOTFILES_DIR" commit -m "sync: update $repo_subdir/$rel_path from HOME"
      echo "  Updated repo and symlinked $display_path"
      break
      ;;
    k | K)
      # 3-way merge using git merge-file with empty base
      local base_tmp
      base_tmp=$(mktemp)
      echo ""
      if git merge-file -p "$src" "$base_tmp" "$dest" >"${src}.merged"; then
        mv "${src}.merged" "$src"
        rm -f "$base_tmp"
        echo "  Merged successfully (no conflicts)"
      else
        mv "${src}.merged" "$src"
        rm -f "$base_tmp"
        echo "  Merge has conflicts that need manual resolution."
        read -rp "  Open editor to resolve? [Y/n]: " open_editor
        if [[ ! "$open_editor" =~ ^[Nn]$ ]]; then
          if command -v code &>/dev/null; then
            code --wait "$src"
          else
            ${EDITOR:-vim} "$src"
          fi
        fi
      fi
      rm -f "$dest"
      ln -s "$src" "$dest"
      git -C "$DOTFILES_DIR" add "$src"
      git -C "$DOTFILES_DIR" commit -m "sync: merge $repo_subdir/$rel_path with HOME"
      echo "  Merged, committed, and symlinked"
      break
      ;;
    s | S)
      echo "  Skipped $display_path"
      break
      ;;
    d | D)
      echo ""
      if [[ -t 1 ]]; then
        diff --color=always -u "$src" "$dest" || true
      else
        diff -u "$src" "$dest" || true
      fi
      echo ""
      ;;
    *)
      echo "  Invalid choice. Please enter r, h, k, s, or d."
      ;;
    esac
  done
}

# Ensure every script under _home/.local/bin is reachable from ~/.local/bin,
# preserving subdirectory structure (e.g. lib/ helpers sourced by the scripts).
# Unlike link_home_file/link_home_dir, this never diffs, prompts, or syncs
# HOME back into the repo -- ~/.local/bin is a shared PATH directory other
# tools also install into, so we only ever add our own symlinks, never
# overwrite a file that isn't already one of them.
ensure_local_bin() {
  local repo_bin="$DOTFILES_DIR/_home/.local/bin"
  local home_bin="$HOME_DIR/.local/bin"

  if [[ ! -d "$repo_bin" ]]; then
    return 0
  fi

  echo ""
  echo "Linking ~/.local/bin scripts..."

  local file rel_path dest dest_dir
  while IFS= read -r -d '' file <&3; do
    rel_path="${file#"$repo_bin"/}"
    dest="$home_bin/$rel_path"
    dest_dir="$(dirname "$dest")"
    mkdir -p "$dest_dir"

    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$file" ]]; then
      continue
    fi

    if [[ -e "$dest" ]] && [[ ! -L "$dest" ]]; then
      echo "  Skipped (not ours, left as-is): ~/.local/bin/$rel_path" >&2
      continue
    fi

    ln -sfn "$file" "$dest"
    echo "  Linked: ~/.local/bin/$rel_path"
  done 3< <(find "$repo_bin" -type f -print0)
}

# Symlink all files in a repo subdir to the corresponding home location.
# Usage: link_home_dir <repo_subdir> <home_subdir>
link_home_dir() {
  local repo_subdir="$1"
  local home_subdir="$2"
  local repo_path="$DOTFILES_DIR/$repo_subdir"

  if [[ ! -d "$repo_path" ]]; then
    return 0
  fi

  echo ""
  echo "Symlinking ~/$home_subdir files..."

  # Use a NUL-delimited read loop rather than `mapfile`: `mapfile` is a bash
  # 4.0+ builtin, but the Homebrew wrapper runs under /bin/bash, which on macOS
  # is Apple's frozen bash 3.2 (no `mapfile`). Reading from a process
  # substitution keeps link_home_file in the current shell, and this avoids an
  # empty-array expansion that would also trip `set -u` on bash 3.2.
  local file rel_path
  # Read the file list on fd 3, NOT the loop's own stdin (fd 0) — otherwise
  # this redirect silently steals stdin from link_home_file's nested
  # interactive conflict prompt, making -t 0 always false even when this is
  # run from a real terminal. (Confirmed by testing under a real pty: the
  # prompt never appeared until this was fixed.)
  while IFS= read -r -d '' file <&3; do
    rel_path="${file#"$repo_path"/}"
    link_home_file "$repo_subdir" "$home_subdir" "$rel_path"
  done 3< <(find "$repo_path" -type f -print0)
}

# Clone $1 into $HOME_DIR/.dotfiles as a REAL git checkout, instead of the
# usual `ln -sfn "$DOTFILES_DIR" "$HOME_DIR/.dotfiles"` symlink, and repoint
# DOTFILES_DIR (and TEMPLATES_DIR) at it so the rest of `wire` treats the
# fresh clone as the source of truth for everything else it symlinks —
# otherwise ~/.dotfiles would be a nice real clone while every other
# symlink still pointed into the (typically read-only-ish, Homebrew-owned)
# bundle, which defeats the point of cloning a personal, editable checkout.
#
# Sets the global DOTFILES_DIR/TEMPLATES_DIR on success. Never destroys an
# existing ~/.dotfiles that isn't one we created ourselves (a plain
# symlink, or empty/absent) — a real directory or a clone of a DIFFERENT
# repo is left untouched and this returns failure instead. If ~/.dotfiles is
# already a clean checkout of $1, fetches and fast-forwards it; a dirty
# tree or a non-fast-forwardable history is left alone rather than stashed
# or rebased.
clone_repo_to_home_dotfiles() {
  local repo_url="$1"
  local dest="$HOME_DIR/.dotfiles"

  if [[ -d "$dest/.git" ]]; then
    local existing_url
    existing_url="$(git -C "$dest" remote get-url origin 2>/dev/null || true)"
    if [[ -n "$existing_url" && "$existing_url" != "$repo_url" ]]; then
      echo "  ~/.dotfiles is already a git checkout of a different repo ($existing_url)." >&2
      echo "  Not touching it — move it aside or remove it, then re-run with --repo." >&2
      return 1
    fi
    # Bring it up to date, but only when it's safe: a dirty working tree or a
    # diverged/missing upstream means the user has their own local commits or
    # edits, and silently rewriting those is exactly the kind of destructive
    # surprise `wire` should never spring on a re-run — leave it as-is and
    # say so instead of stashing, rebasing, or force-updating anything.
    if [[ -n "$(git -C "$dest" status --porcelain 2>/dev/null)" ]]; then
      echo "  ~/.dotfiles is already a checkout of $repo_url but has uncommitted changes; leaving it as-is (not fetching)."
    elif git -C "$dest" fetch --quiet origin 2>/dev/null && git -C "$dest" merge --ff-only --quiet '@{upstream}' 2>/dev/null; then
      echo "  ~/.dotfiles is already a checkout of $repo_url; fetched and fast-forwarded to the latest."
    else
      echo "  ~/.dotfiles is already a checkout of $repo_url; could not fast-forward (no upstream, or local commits ahead) — leaving it as-is."
    fi
    # Canonicalize (pwd -P) so this matches what resolve_dotfiles_dir will
    # produce on later invocations (cd .. && pwd -P) — a raw $dest here
    # would mismatch cmd_check's plain string comparisons on any machine
    # where a path component is itself a symlink (e.g. macOS's /tmp ->
    # /private/tmp), since the symlinks we are about to create/verify get
    # compared by their literal recorded target, not by realpath equality.
    DOTFILES_DIR="$(cd "$dest" && pwd -P)"
    TEMPLATES_DIR="$DOTFILES_DIR/templates"
    return 0
  fi

  if [[ -L "$dest" ]]; then
    echo "  ~/.dotfiles is currently a symlink -> $(readlink "$dest"); removing it to clone a real checkout there."
    rm -f "$dest"
  elif [[ -e "$dest" ]]; then
    echo "  ~/.dotfiles already exists and is neither a git checkout nor a symlink we manage." >&2
    echo "  Not touching it — move it aside or remove it, then re-run with --repo." >&2
    return 1
  fi

  echo "  Cloning $repo_url to $dest..."
  git clone "$repo_url" "$dest" || return 1
  # Canonicalize for the same reason as the already-cloned branch above.
  DOTFILES_DIR="$(cd "$dest" && pwd -P)"
  TEMPLATES_DIR="$DOTFILES_DIR/templates"
}

# Point iTerm2's OS-level default bookmark at the named profile from
# custom-profiles.json, so new windows/tabs use it without a manual pick in
# iTerm2's preferences. macOS-only (no-op elsewhere, e.g. the Linux wire-test
# container); skip with DOTFILES_SKIP_ITERM_DEFAULT=1 — `defaults write`
# targets the real user's preference domain by UID, not $HOME, so it can't be
# sandboxed into a fake $HOME the way the rest of `wire` is tested (used by
# wire-test-macos to keep that job from touching the runner's real plist).
# Usage: set_default_iterm_profile <profile-name>
set_default_iterm_profile() {
  local profile_name="$1"

  [[ -n "${DOTFILES_SKIP_ITERM_DEFAULT:-}" ]] && return 0
  [[ "$(uname -s)" == "Darwin" ]] || return 0
  command -v defaults >/dev/null 2>&1 || return 0

  local profiles_json="$DOTFILES_DIR/_home/Library/Application Support/iTerm2/DynamicProfiles/custom-profiles.json"
  if [[ ! -f "$profiles_json" ]]; then
    return 0
  fi

  # No jq dependency in this formula, so extract the Guid with awk: track the
  # most recent "Name" seen and print the "Guid" that follows a matching one.
  local guid
  guid="$(awk -v name="$profile_name" '
    /"Name":/ {
      current = $0
      sub(/.*"Name": *"/, "", current)
      sub(/".*/, "", current)
    }
    /"Guid":/ && current == name {
      guid = $0
      sub(/.*"Guid": *"/, "", guid)
      sub(/".*/, "", guid)
      print guid
      exit
    }
  ' "$profiles_json")"

  if [[ -z "$guid" ]]; then
    echo "  Warning: iTerm2 profile \"$profile_name\" not found in custom-profiles.json; skipping." >&2
    return 0
  fi

  defaults write com.googlecode.iterm2 "Default Bookmark Guid" -string "$guid"
  echo "  Default Bookmark Guid → $guid ($profile_name)"
}

cmd_wire() {
  # Parse wire-specific options.
  local repo_url=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -y | --yes | --non-interactive)
      NONINTERACTIVE=1
      ;;
    --repo)
      shift
      [[ $# -gt 0 ]] || {
        echo "dotfiles wire: --repo requires a URL or path argument" >&2
        return 1
      }
      repo_url="$1"
      ;;
    -h | --help)
      echo "Usage: dotfiles wire [--yes] [--repo <url>]"
      echo ""
      echo "Deploy dotfiles from $DOTFILES_DIR into \$HOME."
      echo "  --yes, --non-interactive  Never prompt; skip conflicting .config files."
      echo "  --repo <url>              Clone <url> to ~/.dotfiles as a real git"
      echo "                            checkout (instead of symlinking ~/.dotfiles"
      echo "                            to the bundled/installed copy), then wire"
      echo "                            everything else from that checkout. Useful"
      echo "                            for the Homebrew formula's post_install, so"
      echo "                            a fresh machine ends up with its own"
      echo "                            editable, independently git-tracked"
      echo "                            ~/.dotfiles rather than a symlink into"
      echo "                            Homebrew's managed copy."
      echo ""
      echo "  When run via the Homebrew-installed CLI (not shadowed by direnv"
      echo "  in a checkout), --repo defaults to this repo's own URL — so a"
      echo "  fresh install ends up with a real, editable ~/.dotfiles checkout"
      echo "  instead of a symlink into the bundled copy. Pass --repo explicitly"
      echo "  to wire a different dotfiles repo instead."
      return 0
      ;;
    *)
      echo "dotfiles wire: unknown option: $1" >&2
      return 1
      ;;
    esac
    shift
  done

  # No explicit --repo: default to this repo's own URL, but only when running
  # via the Homebrew wrapper (the only thing that sets DOTFILES_DEFAULT_REPO_URL).
  # Inside a dev checkout (direnv-shadowed), this stays empty, so `wire` keeps
  # symlinking ~/.dotfiles to the checkout you're actually running from instead
  # of cloning a redundant second copy of itself.
  if [[ -z "$repo_url" && -n "$DOTFILES_DEFAULT_REPO_URL" ]]; then
    repo_url="$DOTFILES_DEFAULT_REPO_URL"
  fi

  local cloned=0
  if [[ -n "$repo_url" ]]; then
    clone_repo_to_home_dotfiles "$repo_url" || return 1
    cloned=1
  fi

  echo "Wiring dotfiles from $DOTFILES_DIR to $HOME_DIR..."
  echo "Dotfiles directory: $DOTFILES_DIR"

  # ---------------------------------------------------------------------------
  # Directory symlinks
  # ---------------------------------------------------------------------------
  echo ""
  echo "Creating directory symlinks..."

  if [[ "$cloned" -eq 1 ]]; then
    # ~/.dotfiles IS the clone itself (see clone_repo_to_home_dotfiles) —
    # nothing to symlink, and doing so would try to replace the real
    # checkout we just made or reused.
    echo "  $HOME_DIR/.dotfiles is a git checkout of $repo_url (not a symlink)"
  else
    # ~/.dotfiles -> repo root (used by check and as a resolution fallback)
    ln -sfn "$DOTFILES_DIR" "$HOME_DIR/.dotfiles"
    echo "  $HOME_DIR/.dotfiles → $DOTFILES_DIR"
  fi

  # These four ~/.*.d symlinks point at the _home/ drop-in dirs — that's where
  # personal scripts live and where a user adds new ones. (internal/'s own
  # interactive.d — antidote, staleness-check — is sourced directly by the rc
  # loaders via $DOTFILES_DIR, not exposed as a mutable ~ location.) The
  # symlink itself is still force-created; only the files it points at are
  # personal.
  create_symlink "$DOTFILES_DIR/_home/profile.d" "$HOME_DIR/.profile.d"
  create_symlink "$DOTFILES_DIR/_home/interactive.d" "$HOME_DIR/.interactive.d"
  create_symlink "$DOTFILES_DIR/_home/startup.d" "$HOME_DIR/.startup.d"
  create_symlink "$DOTFILES_DIR/_home/update.d" "$HOME_DIR/.update.d"

  # ---------------------------------------------------------------------------
  # Managed sections in shell RC files
  # ---------------------------------------------------------------------------
  echo ""
  echo "Injecting managed sections into shell RC files..."

  # Zsh files
  inject_managed_section "$HOME_DIR/.zshrc" "$TEMPLATES_DIR/zsh/rc.zsh"
  inject_managed_section "$HOME_DIR/.zshenv" "$TEMPLATES_DIR/zsh/env.zsh"
  inject_managed_section "$HOME_DIR/.zprofile" "$TEMPLATES_DIR/zsh/profile.zsh"

  # Bash files
  inject_managed_section "$HOME_DIR/.bashrc" "$TEMPLATES_DIR/bash/rc.bash"
  inject_managed_section "$HOME_DIR/.bash_profile" "$TEMPLATES_DIR/bash/profile.bash"

  # ---------------------------------------------------------------------------
  # .config and Library file symlinks
  # ---------------------------------------------------------------------------
  link_home_dir "_home/.config" ".config"
  link_home_dir "_home/Library" "Library"
  ensure_local_bin

  echo ""
  echo "Setting iTerm2 default profile..."
  set_default_iterm_profile "Default"

  # ---------------------------------------------------------------------------
  # Summary
  # ---------------------------------------------------------------------------
  echo ""
  echo "Wiring complete!"
  echo ""
  echo "Next steps:"
  echo "  1. Open a new terminal to test the changes"
  echo "  2. Verify functions work: cc-tmp, cc-newsession, cc-resume"
  echo "  3. Check iTerm profile switching when changing directories"
  echo ""
  echo "To run startup scripts manually:"
  echo "  dotfiles startup"
}

# -----------------------------------------------------------------------------
# check
# -----------------------------------------------------------------------------

# The status messages below print literal "~/..." as human-readable shorthand;
# the tilde is intentional display text, not a path meant to expand.
# shellcheck disable=SC2088
cmd_check() {
  local quiet=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -q | --quiet) quiet=1 ;;
    -h | --help)
      echo "Usage: dotfiles check [--quiet]"
      echo ""
      echo "Report whether the dotfiles are wired into \$HOME."
      echo "Exits 0 if wired, non-zero otherwise."
      return 0
      ;;
    *)
      echo "dotfiles check: unknown option: $1" >&2
      return 1
      ;;
    esac
    shift
  done

  local ok=0
  report() {
    local status="$1" msg="$2"
    [[ -n "$quiet" ]] && return 0
    echo "  [$status] $msg"
  }

  # 1. ~/.dotfiles is wired: either a symlink to $DOTFILES_DIR (the normal
  #    case), or IS $DOTFILES_DIR itself as a real git checkout (the --repo
  #    case — resolve_dotfiles_dir resolves straight to it, so there's
  #    nothing to symlink; ~/.dotfiles being the real checkout is correct).
  if [[ -L "$HOME_DIR/.dotfiles" ]] && [[ "$(cd "$HOME_DIR/.dotfiles" 2>/dev/null && pwd -P)" == "$(cd "$DOTFILES_DIR" && pwd -P)" ]]; then
    report OK "~/.dotfiles → $DOTFILES_DIR"
  elif [[ -d "$HOME_DIR/.dotfiles/.git" ]] && [[ "$(cd "$HOME_DIR/.dotfiles" 2>/dev/null && pwd -P)" == "$(cd "$DOTFILES_DIR" && pwd -P)" ]]; then
    report OK "~/.dotfiles is a git checkout (same path as \$DOTFILES_DIR)"
  else
    report "  " "~/.dotfiles is not linked to $DOTFILES_DIR"
    ok=1
  fi

  # 2. Directory symlinks.
  local pair src dest
  for pair in \
    "_home/profile.d:.profile.d" \
    "_home/interactive.d:.interactive.d" \
    "_home/startup.d:.startup.d" \
    "_home/update.d:.update.d"; do
    src="$DOTFILES_DIR/${pair%%:*}"
    dest="$HOME_DIR/${pair##*:}"
    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
      report OK "~/${pair##*:} → $src"
    else
      report "  " "~/${pair##*:} is not linked"
      ok=1
    fi
  done

  # 3. Managed sections in shell rc files.
  local rc
  for rc in .zshrc .zshenv .zprofile; do
    if [[ -f "$HOME_DIR/$rc" ]] && grep -q "$MARKER_BEGIN" "$HOME_DIR/$rc" 2>/dev/null; then
      report OK "managed section present in ~/$rc"
    else
      report "  " "managed section missing from ~/$rc"
      ok=1
    fi
  done

  if [[ -z "$quiet" ]]; then
    echo ""
    if [[ "$ok" -eq 0 ]]; then
      echo "dotfiles: wired ✓"
    else
      echo "dotfiles: not fully wired. Run 'dotfiles wire' to fix."
    fi
  fi

  return "$ok"
}

# -----------------------------------------------------------------------------
# ensure-wired (used by Homebrew post_install; must never fail the install)
# -----------------------------------------------------------------------------

cmd_ensure_wired() {
  if [[ -n "${DOTFILES_SKIP_AUTOWIRE:-}" ]]; then
    echo "dotfiles: DOTFILES_SKIP_AUTOWIRE set; skipping auto-wire."
    return 0
  fi

  if cmd_check --quiet; then
    echo "dotfiles: already wired; nothing to do."
    return 0
  fi

  echo "dotfiles: not wired yet; wiring non-interactively..."
  # Never let wiring failure abort a Homebrew install.
  NONINTERACTIVE=1 cmd_wire --yes || {
    echo "dotfiles: auto-wire did not complete cleanly; run 'dotfiles wire' manually." >&2
    return 0
  }
  return 0
}

# -----------------------------------------------------------------------------
# staleness-check (called from shell startup; must never fail or be noisy)
# -----------------------------------------------------------------------------

# Default minimum time between checks: 16 hours, in seconds. Overridable via
# DOTFILES_STALENESS_CHECK_INTERVAL for testing or personal preference.
DOTFILES_STALENESS_CHECK_INTERVAL_DEFAULT=57600

cmd_staleness_check() {
  local force=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --force)
      force=1
      ;;
    -h | --help)
      echo "Usage: dotfiles staleness-check [--force]"
      echo ""
      echo "Warn on stderr if \$DOTFILES_DIR is on a different branch than the"
      echo "remote's default branch, or is behind that branch as of the last"
      echo "fetch. Silent (and a no-op) if run again within"
      echo "\$DOTFILES_STALENESS_CHECK_INTERVAL seconds (default 16h) of the last"
      echo "check, or if \$DOTFILES_DIR isn't a git checkout."
      echo ""
      echo "  --force  Ignore the interval and check now."
      echo ""
      echo "Env:"
      echo "  DOTFILES_SKIP_STALENESS_CHECK     Set to disable entirely."
      echo "  DOTFILES_STALENESS_CHECK_INTERVAL Minimum seconds between checks."
      return 0
      ;;
    *)
      echo "dotfiles staleness-check: unknown option: $1" >&2
      return 1
      ;;
    esac
    shift
  done

  # Opt-out escape hatch.
  if [[ -n "${DOTFILES_SKIP_STALENESS_CHECK:-}" ]]; then
    return 0
  fi

  local interval state_file now last
  interval="${DOTFILES_STALENESS_CHECK_INTERVAL:-$DOTFILES_STALENESS_CHECK_INTERVAL_DEFAULT}"
  state_file="${DOTFILES_STALENESS_STATE_FILE:-${XDG_CACHE_HOME:-$HOME_DIR/.cache}/dotfiles/last-staleness-check}"

  now="$(date +%s)"
  last=0
  if [[ -f "$state_file" ]]; then
    last="$(cat "$state_file" 2>/dev/null || echo 0)"
    [[ "$last" =~ ^[0-9]+$ ]] || last=0
  fi

  # Within the interval: skip silently, and don't touch the state file.
  if [[ -z "$force" ]] && ((now - last < interval)); then
    return 0
  fi

  # Record that a check happened now, regardless of what it finds below --
  # this is a local/offline comparison (no `git fetch`), so it's always cheap.
  mkdir -p "$(dirname "$state_file")"
  printf '%s\n' "$now" >"$state_file"

  # Only meaningful for an actual git checkout. The Homebrew-installed copy
  # (the common case for non-developer machines) is a plain tarball with no
  # .git directory, so this is a silent no-op there.
  if ! git -C "$DOTFILES_DIR" rev-parse --git-dir &>/dev/null; then
    return 0
  fi

  # Find the remote's default branch without touching the network: prefer
  # the recorded origin/HEAD symlink (set by `git clone`), falling back to
  # checking for a conventionally-named branch if that's missing (e.g. a
  # shallow/CI checkout that never set it).
  local default_branch candidate
  default_branch="$(git -C "$DOTFILES_DIR" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
  if [[ -z "$default_branch" ]]; then
    for candidate in main master; do
      if git -C "$DOTFILES_DIR" show-ref --verify --quiet "refs/remotes/origin/$candidate"; then
        default_branch="$candidate"
        break
      fi
    done
  fi
  # Can't tell what the remote's default branch is (no remote, never
  # fetched) -- nothing to compare against.
  if [[ -z "$default_branch" ]]; then
    return 0
  fi

  local current_branch
  current_branch="$(git -C "$DOTFILES_DIR" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

  local reason=""
  if [[ "$current_branch" != "$default_branch" ]]; then
    reason="on ${current_branch:-a detached HEAD} instead of '$default_branch'"
  else
    local behind
    behind="$(git -C "$DOTFILES_DIR" rev-list --count "HEAD..refs/remotes/origin/$default_branch" 2>/dev/null || echo 0)"
    if [[ "$behind" =~ ^[0-9]+$ ]] && ((behind > 0)); then
      reason="$behind commit(s) behind origin/$default_branch as of the last fetch"
    fi
  fi

  if [[ -n "$reason" ]]; then
    echo "dotfiles: warning: $DOTFILES_DIR is $reason." >&2
    echo "  Run: git -C \"$DOTFILES_DIR\" fetch && git -C \"$DOTFILES_DIR\" switch $default_branch && git -C \"$DOTFILES_DIR\" pull" >&2
  fi

  return 0
}

# -----------------------------------------------------------------------------
# startup / update (delegate to the standalone runners)
# -----------------------------------------------------------------------------

cmd_startup() {
  exec "$DOTFILES_DIR/bin/run-startup.sh" "$@"
}

cmd_update() {
  exec "$DOTFILES_DIR/bin/run-updates.sh" "$@"
}

# -----------------------------------------------------------------------------
# help / version / dispatch
# -----------------------------------------------------------------------------

show_version() {
  echo "dotfiles $DOTFILES_VERSION"
}

show_help() {
  cat <<'EOF'
dotfiles - manage deployment of this dotfiles repo into $HOME

USAGE:
  dotfiles <command> [options]

COMMANDS:
  wire            Deploy dotfiles into $HOME (symlinks + managed rc sections)
  check           Report whether dotfiles are wired (exit 0 if wired)
  ensure-wired    Wire only if not already wired (non-interactive, never fails)
  startup         Run the startup.d scripts
  update          Run the update.d scripts
  staleness-check Warn if this checkout is stale relative to its remote

OPTIONS:
  -h, --help      Show this help
  -v, --version   Show version

The global `dotfiles` command is installed by Homebrew. Inside a checkout of the
repo, direnv puts the repo's bin/ first on PATH so this runs against your working
copy. Set DOTFILES_DIR to override which checkout is used.
EOF
}

main() {
  local cmd="${1:-}"
  if [[ $# -gt 0 ]]; then shift; fi

  case "$cmd" in
  -h | --help | help | "")
    show_help
    return 0
    ;;
  -v | --version | version)
    show_version
    return 0
    ;;
  esac

  # All real subcommands need the repo resolved.
  DOTFILES_DIR="$(resolve_dotfiles_dir)"
  TEMPLATES_DIR="$DOTFILES_DIR/templates"

  case "$cmd" in
  wire) cmd_wire "$@" ;;
  check) cmd_check "$@" ;;
  ensure-wired) cmd_ensure_wired "$@" ;;
  startup) cmd_startup "$@" ;;
  update) cmd_update "$@" ;;
  staleness-check) cmd_staleness_check "$@" ;;
  *)
    echo "dotfiles: unknown command: $cmd" >&2
    echo "Run 'dotfiles --help' for usage." >&2
    return 1
    ;;
  esac
}

main "$@"
