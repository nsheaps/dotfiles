#!/usr/bin/env bash
# dotfiles - manage deployment of this dotfiles repo into $HOME
#
# Subcommands:
#   wire            Deploy dotfiles from the repo into $HOME (symlinks +
#                   managed rc sections + .config symlinks).
#   check           Report whether dotfiles are wired into $HOME.
#                   Exits 0 if wired, non-zero otherwise.
#   ensure-wired    Run check; if not wired, run wire non-interactively.
#                   Always exits 0 (used by the Homebrew formula post_install).
#   startup         Run the startup.d scripts (bin/run-startup.sh).
#   update          Run the update.d scripts (bin/run-updates.sh).
#
# This is the global entrypoint installed by the Homebrew formula. When you are
# inside a checkout of the repo, direnv puts the repo's bin/ first on PATH so
# this same script runs against your working copy instead of the installed one.
#
# The repo location is resolved into DOTFILES_DIR (see resolve_dotfiles_dir),
# the single variable the shell config in _home/ relies on.

set -euo pipefail

DOTFILES_VERSION="0.1.0"

# Managed section markers (kept identical across versions so old sections can be
# found and replaced in place).
MARKER_BEGIN="# BEGIN: Managed by dotfiles wire"
MARKER_END="# END: Managed by dotfiles wire"

# -----------------------------------------------------------------------------
# Path / repo resolution
# -----------------------------------------------------------------------------

# Resolve the real directory containing this script, following symlinks.
# Portable (no dependency on `readlink -f`, which BSD/macOS historically lacked).
script_dir() {
  local source="${BASH_SOURCE[0]}" dir
  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}

# Resolve the dotfiles repo root into DOTFILES_DIR. Priority:
#   1. $DOTFILES_DIR if already set and valid (direnv exports this inside a
#      checkout, so local development always wins over the installed copy).
#   2. The script's own location (../_home). Covers both the in-repo copy and
#      the Homebrew install (libexec/bin/dotfiles -> libexec/_home).
#   3. ~/.dotfiles/_home (symlink created by a previous `wire`).
resolve_dotfiles_dir() {
  if [[ -n "${DOTFILES_DIR:-}" && -d "$DOTFILES_DIR/_home" ]]; then
    printf '%s\n' "$DOTFILES_DIR"
    return 0
  fi

  local sdir root
  sdir="$(script_dir)"
  root="$(cd "$sdir/.." && pwd)"
  if [[ -d "$root/_home" ]]; then
    printf '%s\n' "$root"
    return 0
  fi

  if [[ -d "$HOME/.dotfiles/_home" ]]; then
    (cd "$HOME/.dotfiles" && pwd -P)
    return 0
  fi

  echo "dotfiles: error: could not locate the dotfiles repo (no _home/ found)." >&2
  echo "         Set DOTFILES_DIR to your dotfiles checkout and try again." >&2
  return 1
}

# Populated by main() before dispatching to a subcommand.
DOTFILES_DIR=""
TEMPLATES_DIR=""
HOME_DIR="$HOME"

# -----------------------------------------------------------------------------
# wire
# -----------------------------------------------------------------------------

# When true, never prompt: config-file conflicts are skipped (both kept as-is).
NONINTERACTIVE="${DOTFILES_NONINTERACTIVE:-}"

create_symlink() {
  local src="$1"
  local dest="$2"

  if [[ -d "$src" ]]; then
    ln -sfn "$src" "$dest"
    echo "  $dest → $src"
  else
    echo "  Warning: Source directory does not exist: $src"
  fi
}

# Inject or update a managed section in a file.
# Usage: inject_managed_section <target_file> <template_file>
inject_managed_section() {
  local target="$1"
  local template="$2"

  if [[ ! -f "$template" ]]; then
    echo "  Warning: Template not found: $template"
    return 1
  fi

  # Build the managed section content with DOTFILES_DIR expanded
  local section_content
  section_content="$MARKER_BEGIN
export DOTFILES_DIR=\"$DOTFILES_DIR\"
$(cat "$template")
$MARKER_END"

  # Create target file if it doesn't exist
  if [[ ! -f "$target" ]]; then
    echo "$section_content" >"$target"
    echo "  Created $target with managed section"
    return 0
  fi

  # Check if managed section already exists
  if grep -q "$MARKER_BEGIN" "$target" 2>/dev/null; then
    # Replace existing managed section
    local tmpfile content_file
    tmpfile=$(mktemp)
    content_file=$(mktemp)

    # Write content to temp file (awk can't handle newlines in -v)
    echo "$section_content" >"$content_file"

    # Use awk to replace the section, reading replacement from file
    awk -v begin="$MARKER_BEGIN" -v end="$MARKER_END" -v cfile="$content_file" '
      $0 ~ begin { skip=1; while ((getline line < cfile) > 0) print line; close(cfile); next }
      $0 ~ end { skip=0; next }
      !skip { print }
    ' "$target" >"$tmpfile"

    mv "$tmpfile" "$target"
    rm -f "$content_file"
    echo "  Updated managed section in $target"
  else
    # Append managed section to end of file
    echo "" >>"$target"
    echo "$section_content" >>"$target"
    echo "  Appended managed section to $target"
  fi
}

# Symlink a single file from repo to HOME with conflict resolution.
# Usage: link_home_file <repo_subdir> <home_subdir> <relative_path>
# Example: link_home_file "_home/.config" ".config" "mise/config.toml"
link_home_file() {
  local repo_subdir="$1"
  local home_subdir="$2"
  local rel_path="$3"
  local src="$DOTFILES_DIR/$repo_subdir/$rel_path"
  local dest="$HOME_DIR/$home_subdir/$rel_path"
  # Tilde is intentional for display, not expansion
  # shellcheck disable=SC2088
  local display_path="~/$home_subdir/$rel_path"
  local dest_dir
  dest_dir="$(dirname "$dest")"

  # Skip README files - they're for documentation only
  if [[ "$(basename "$rel_path")" == "README.md" ]]; then
    return 0
  fi

  # Create destination directory if needed
  if [[ ! -d "$dest_dir" ]]; then
    mkdir -p "$dest_dir"
  fi

  # Already a correct symlink
  if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
    echo "  Symlink OK: $display_path"
    return 0
  fi

  # If destination doesn't exist, just symlink
  if [[ ! -e "$dest" ]]; then
    ln -s "$src" "$dest"
    echo "  Symlinked: $display_path"
    return 0
  fi

  # If it's a symlink pointing elsewhere, update it
  if [[ -L "$dest" ]]; then
    rm -f "$dest"
    ln -s "$src" "$dest"
    echo "  Updated symlink: $display_path"
    return 0
  fi

  # It's a regular file - check if it matches
  if diff -q "$src" "$dest" >/dev/null 2>&1; then
    # Files match - replace with symlink
    rm -f "$dest"
    ln -s "$src" "$dest"
    echo "  Converted to symlink: $display_path"
    return 0
  fi

  # Files differ. In non-interactive mode (or without a TTY) we cannot safely
  # prompt, so skip and leave both copies untouched.
  if [[ -n "$NONINTERACTIVE" ]] || [[ ! -t 0 ]]; then
    echo "  CONFLICT (skipped): $display_path differs from repo version; left as-is." >&2
    return 0
  fi

  # Files differ - prompt user
  echo ""
  echo "  CONFLICT: $display_path differs from repo version"
  echo ""
  echo "  --- Diff (repo vs home) ---"
  if [[ -t 1 ]]; then
    diff --color=always -u "$src" "$dest" || true
  else
    diff -u "$src" "$dest" || true
  fi
  echo "  --- End diff ---"
  echo ""
  echo "  Options:"
  echo "    [r] Overwrite HOME with repo version"
  echo "    [h] Overwrite repo with HOME version (and commit)"
  echo "    [k] Keep both: 3-way merge with empty base (auto-merges, conflicts if needed)"
  echo "    [s] Skip (keep both as-is, no sync)"
  echo "    [d] Show full diff"
  echo ""

  while true; do
    read -rp "  Choice [r/h/k/s/d]: " choice
    case "$choice" in
    r | R)
      rm -f "$dest"
      ln -s "$src" "$dest"
      echo "  Symlinked $display_path to repo version"
      break
      ;;
    h | H)
      cp "$dest" "$src"
      rm -f "$dest"
      ln -s "$src" "$dest"
      git -C "$DOTFILES_DIR" add "$src"
      git -C "$DOTFILES_DIR" commit -m "sync: update $repo_subdir/$rel_path from HOME"
      echo "  Updated repo and symlinked $display_path"
      break
      ;;
    k | K)
      # 3-way merge using git merge-file with empty base
      local base_tmp
      base_tmp=$(mktemp)
      echo ""
      if git merge-file -p "$src" "$base_tmp" "$dest" >"${src}.merged"; then
        mv "${src}.merged" "$src"
        rm -f "$base_tmp"
        echo "  Merged successfully (no conflicts)"
      else
        mv "${src}.merged" "$src"
        rm -f "$base_tmp"
        echo "  Merge has conflicts that need manual resolution."
        read -rp "  Open editor to resolve? [Y/n]: " open_editor
        if [[ ! "$open_editor" =~ ^[Nn]$ ]]; then
          if command -v code &>/dev/null; then
            code --wait "$src"
          else
            ${EDITOR:-vim} "$src"
          fi
        fi
      fi
      rm -f "$dest"
      ln -s "$src" "$dest"
      git -C "$DOTFILES_DIR" add "$src"
      git -C "$DOTFILES_DIR" commit -m "sync: merge $repo_subdir/$rel_path with HOME"
      echo "  Merged, committed, and symlinked"
      break
      ;;
    s | S)
      echo "  Skipped $display_path"
      break
      ;;
    d | D)
      echo ""
      if [[ -t 1 ]]; then
        diff --color=always -u "$src" "$dest" || true
      else
        diff -u "$src" "$dest" || true
      fi
      echo ""
      ;;
    *)
      echo "  Invalid choice. Please enter r, h, k, s, or d."
      ;;
    esac
  done
}

# Symlink all files in a repo subdir to the corresponding home location.
# Usage: link_home_dir <repo_subdir> <home_subdir>
link_home_dir() {
  local repo_subdir="$1"
  local home_subdir="$2"
  local repo_path="$DOTFILES_DIR/$repo_subdir"

  if [[ ! -d "$repo_path" ]]; then
    return 0
  fi

  echo ""
  echo "Symlinking ~/$home_subdir files..."

  local files
  mapfile -d '' files < <(find "$repo_path" -type f -print0)

  for file in "${files[@]}"; do
    local rel_path="${file#"$repo_path"/}"
    link_home_file "$repo_subdir" "$home_subdir" "$rel_path"
  done
}

cmd_wire() {
  # Parse wire-specific options.
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -y | --yes | --non-interactive)
      NONINTERACTIVE=1
      ;;
    -h | --help)
      echo "Usage: dotfiles wire [--yes]"
      echo ""
      echo "Deploy dotfiles from $DOTFILES_DIR into \$HOME."
      echo "  --yes, --non-interactive  Never prompt; skip conflicting .config files."
      return 0
      ;;
    *)
      echo "dotfiles wire: unknown option: $1" >&2
      return 1
      ;;
    esac
    shift
  done

  echo "Wiring dotfiles from $DOTFILES_DIR to $HOME_DIR..."
  echo "Dotfiles directory: $DOTFILES_DIR"

  # ---------------------------------------------------------------------------
  # Directory symlinks
  # ---------------------------------------------------------------------------
  echo ""
  echo "Creating directory symlinks..."

  # ~/.dotfiles -> repo root (used by check and as a resolution fallback)
  ln -sfn "$DOTFILES_DIR" "$HOME_DIR/.dotfiles"
  echo "  $HOME_DIR/.dotfiles → $DOTFILES_DIR"

  create_symlink "$DOTFILES_DIR/_home/profile.d" "$HOME_DIR/.profile.d"
  create_symlink "$DOTFILES_DIR/_home/interactive.d" "$HOME_DIR/.interactive.d"
  create_symlink "$DOTFILES_DIR/_home/startup.d" "$HOME_DIR/.startup.d"
  create_symlink "$DOTFILES_DIR/_home/update.d" "$HOME_DIR/.update.d"

  # ---------------------------------------------------------------------------
  # Managed sections in shell RC files
  # ---------------------------------------------------------------------------
  echo ""
  echo "Injecting managed sections into shell RC files..."

  # Zsh files
  inject_managed_section "$HOME_DIR/.zshrc" "$TEMPLATES_DIR/zsh/rc.zsh"
  inject_managed_section "$HOME_DIR/.zshenv" "$TEMPLATES_DIR/zsh/env.zsh"
  inject_managed_section "$HOME_DIR/.zprofile" "$TEMPLATES_DIR/zsh/profile.zsh"

  # Bash files
  inject_managed_section "$HOME_DIR/.bashrc" "$TEMPLATES_DIR/bash/rc.bash"
  inject_managed_section "$HOME_DIR/.bash_profile" "$TEMPLATES_DIR/bash/profile.bash"

  # ---------------------------------------------------------------------------
  # .config and Library file symlinks
  # ---------------------------------------------------------------------------
  link_home_dir "_home/.config" ".config"
  link_home_dir "_home/Library" "Library"

  # ---------------------------------------------------------------------------
  # Summary
  # ---------------------------------------------------------------------------
  echo ""
  echo "Wiring complete!"
  echo ""
  echo "Next steps:"
  echo "  1. Open a new terminal to test the changes"
  echo "  2. Verify functions work: cc-tmp, cc-newsession, cc-resume"
  echo "  3. Check iTerm profile switching when changing directories"
  echo ""
  echo "To run startup scripts manually:"
  echo "  dotfiles startup"
}

# -----------------------------------------------------------------------------
# check
# -----------------------------------------------------------------------------

# The status messages below print literal "~/..." as human-readable shorthand;
# the tilde is intentional display text, not a path meant to expand.
# shellcheck disable=SC2088
cmd_check() {
  local quiet=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -q | --quiet) quiet=1 ;;
    -h | --help)
      echo "Usage: dotfiles check [--quiet]"
      echo ""
      echo "Report whether the dotfiles are wired into \$HOME."
      echo "Exits 0 if wired, non-zero otherwise."
      return 0
      ;;
    *)
      echo "dotfiles check: unknown option: $1" >&2
      return 1
      ;;
    esac
    shift
  done

  local ok=0
  report() {
    local status="$1" msg="$2"
    [[ -n "$quiet" ]] && return 0
    echo "  [$status] $msg"
  }

  # 1. ~/.dotfiles symlink points at the repo root.
  if [[ -L "$HOME_DIR/.dotfiles" ]] && [[ "$(cd "$HOME_DIR/.dotfiles" 2>/dev/null && pwd -P)" == "$(cd "$DOTFILES_DIR" && pwd -P)" ]]; then
    report OK "~/.dotfiles → $DOTFILES_DIR"
  else
    report "  " "~/.dotfiles is not linked to $DOTFILES_DIR"
    ok=1
  fi

  # 2. Directory symlinks.
  local pair src dest
  for pair in \
    "_home/profile.d:.profile.d" \
    "_home/interactive.d:.interactive.d" \
    "_home/startup.d:.startup.d" \
    "_home/update.d:.update.d"; do
    src="$DOTFILES_DIR/${pair%%:*}"
    dest="$HOME_DIR/${pair##*:}"
    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
      report OK "~/${pair##*:} → $src"
    else
      report "  " "~/${pair##*:} is not linked"
      ok=1
    fi
  done

  # 3. Managed sections in shell rc files.
  local rc
  for rc in .zshrc .zshenv .zprofile; do
    if [[ -f "$HOME_DIR/$rc" ]] && grep -q "$MARKER_BEGIN" "$HOME_DIR/$rc" 2>/dev/null; then
      report OK "managed section present in ~/$rc"
    else
      report "  " "managed section missing from ~/$rc"
      ok=1
    fi
  done

  if [[ -z "$quiet" ]]; then
    echo ""
    if [[ "$ok" -eq 0 ]]; then
      echo "dotfiles: wired ✓"
    else
      echo "dotfiles: not fully wired. Run 'dotfiles wire' to fix."
    fi
  fi

  return "$ok"
}

# -----------------------------------------------------------------------------
# ensure-wired (used by Homebrew post_install; must never fail the install)
# -----------------------------------------------------------------------------

cmd_ensure_wired() {
  if [[ -n "${DOTFILES_SKIP_AUTOWIRE:-}" ]]; then
    echo "dotfiles: DOTFILES_SKIP_AUTOWIRE set; skipping auto-wire."
    return 0
  fi

  if cmd_check --quiet; then
    echo "dotfiles: already wired; nothing to do."
    return 0
  fi

  echo "dotfiles: not wired yet; wiring non-interactively..."
  # Never let wiring failure abort a Homebrew install.
  NONINTERACTIVE=1 cmd_wire --yes || {
    echo "dotfiles: auto-wire did not complete cleanly; run 'dotfiles wire' manually." >&2
    return 0
  }
  return 0
}

# -----------------------------------------------------------------------------
# startup / update (delegate to the standalone runners)
# -----------------------------------------------------------------------------

cmd_startup() {
  exec "$DOTFILES_DIR/bin/run-startup.sh" "$@"
}

cmd_update() {
  exec "$DOTFILES_DIR/bin/run-updates.sh" "$@"
}

# -----------------------------------------------------------------------------
# help / version / dispatch
# -----------------------------------------------------------------------------

show_version() {
  echo "dotfiles $DOTFILES_VERSION"
}

show_help() {
  cat <<'EOF'
dotfiles - manage deployment of this dotfiles repo into $HOME

USAGE:
  dotfiles <command> [options]

COMMANDS:
  wire            Deploy dotfiles into $HOME (symlinks + managed rc sections)
  check           Report whether dotfiles are wired (exit 0 if wired)
  ensure-wired    Wire only if not already wired (non-interactive, never fails)
  startup         Run the startup.d scripts
  update          Run the update.d scripts

OPTIONS:
  -h, --help      Show this help
  -v, --version   Show version

The global `dotfiles` command is installed by Homebrew. Inside a checkout of the
repo, direnv puts the repo's bin/ first on PATH so this runs against your working
copy. Set DOTFILES_DIR to override which checkout is used.
EOF
}

main() {
  local cmd="${1:-}"
  if [[ $# -gt 0 ]]; then shift; fi

  case "$cmd" in
  -h | --help | help | "")
    show_help
    return 0
    ;;
  -v | --version | version)
    show_version
    return 0
    ;;
  esac

  # All real subcommands need the repo resolved.
  DOTFILES_DIR="$(resolve_dotfiles_dir)"
  TEMPLATES_DIR="$DOTFILES_DIR/templates"

  case "$cmd" in
  wire) cmd_wire "$@" ;;
  check) cmd_check "$@" ;;
  ensure-wired) cmd_ensure_wired "$@" ;;
  startup) cmd_startup "$@" ;;
  update) cmd_update "$@" ;;
  *)
    echo "dotfiles: unknown command: $cmd" >&2
    echo "Run 'dotfiles --help' for usage." >&2
    return 1
    ;;
  esac
}

main "$@"
